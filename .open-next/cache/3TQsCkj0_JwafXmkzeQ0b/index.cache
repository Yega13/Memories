{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><!--3TQsCkj0_JwafXmkzeQ0b--><html lang=\"en\" class=\"__variable_188709 __variable_eea437 h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/card1.jpg\"/><link rel=\"preload\" as=\"image\" href=\"/card2.jpg\"/><link rel=\"preload\" as=\"image\" href=\"/card3.jpg\"/><link rel=\"preload\" as=\"image\" href=\"/card4.jpg\"/><link rel=\"stylesheet\" href=\"/_next/static/css/698e2362ace36ec1.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-1dbe8017801b8c18.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f212684648fcab9.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-bc5ccb68dacfe7d8.js\" async=\"\"></script><script src=\"/_next/static/chunks/44530001-2a95bb40d7cb4c97.js\" async=\"\"></script><script src=\"/_next/static/chunks/586-23ccab3f67b0214a.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-67397725b32eb4cb.js\" async=\"\"></script><title>Memories — Share photos with just a link</title><meta name=\"description\" content=\"Create a shared photo album in seconds. Anyone with the link can view and add photos — no sign-up, no app, no friction.\"/><meta property=\"og:title\" content=\"Memories — Share photos with just a link\"/><meta property=\"og:description\" content=\"Create a shared photo album in seconds. No account needed.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Memories — Share photos with just a link\"/><meta name=\"twitter:description\" content=\"Create a shared photo album in seconds. No account needed.\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"16x16\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><main style=\"background:#FDFAF5;font-family:var(--font-sans)\" class=\"min-h-screen\"><div class=\"relative min-h-screen overflow-hidden\"><div class=\"absolute inset-y-0 right-0 w-full lg:w-[58%]\" style=\"background-image:url(https://live.staticflickr.com/8731/17080622367_6c7109db98_h.jpg);background-size:cover;background-position:center;clip-path:polygon(20% 0%, 100% 0%, 100% 100%, 0% 100%)\"><div class=\"absolute inset-0\" style=\"background:linear-gradient(135deg, rgba(37,79,34,0.45) 0%, rgba(27,58,107,0.25) 100%)\"></div></div><div class=\"absolute inset-y-0 hidden lg:block\" style=\"left:36%;width:130px;background:linear-gradient(to right, #FDFAF5, transparent);z-index:2\"></div><nav class=\"relative z-10 flex items-center justify-between px-8 py-5\" style=\"border-bottom:1px solid rgba(232,224,208,0.6)\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-5 h-5\" aria-hidden=\"true\" style=\"color:#254F22\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg><span style=\"font-family:var(--font-serif);color:#254F22;font-size:1.25rem;font-weight:700\">Memories</span></div><span class=\"text-xs font-medium px-3 py-1 rounded-full\" style=\"background:#EAF0E8;color:#254F22\">Free during beta</span></nav><div class=\"relative z-10 max-w-6xl mx-auto px-8 pt-16 pb-24 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center min-h-[calc(100vh-73px)]\"><div><p class=\"text-sm font-medium uppercase mb-5\" style=\"color:#8B6F4E;letter-spacing:0.15em\">No account · No friction</p><h1 style=\"font-family:var(--font-serif);color:#254F22;font-size:clamp(2.8rem, 5vw, 4rem);line-height:1.1;font-weight:700;margin-bottom:1.5rem\">Every moment,<br/><em style=\"color:#7C4A2D\">beautifully kept</em></h1><p class=\"text-lg leading-relaxed mb-10\" style=\"color:#6B5A4E;max-width:420px\">Create a shared album and let anyone add photos with just a link — no sign-up, no app download.</p><div class=\"rounded-2xl p-6\" style=\"background:#FFFFFF;border:1px solid #DDD5C5;box-shadow:0 4px 32px rgba(37,79,34,0.10)\"><label class=\"block text-sm font-medium mb-2\" style=\"color:#8B6F4E\">Name your album</label><input type=\"text\" placeholder=\"e.g. Summer in Tuscany · 2031\" class=\"w-full rounded-xl px-4 py-3 mb-3 focus:outline-none transition text-base\" style=\"background:#FDFAF5;border:1px solid #DDD5C5;color:#254F22\" maxLength=\"60\" value=\"\"/><button class=\"w-full flex items-center justify-center gap-2 font-semibold rounded-xl py-3 transition hover:opacity-90 disabled:opacity-50\" style=\"background:#254F22;color:#FDFAF5\">Create Album <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button><p class=\"text-xs mt-3 text-center\" style=\"color:#B0A090\">You&#x27;ll receive a private link to manage your album</p></div></div><div class=\"relative hidden lg:flex items-center justify-center\" style=\"height:520px\"><div class=\"absolute rounded-2xl overflow-hidden shadow-2xl\" style=\"top:30px;left:10px;width:200px;height:250px;transform:rotate(-4deg);border:4px solid rgba(255,255,255,0.9)\"><img src=\"/card1.jpg\" alt=\"\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 flex items-end p-3\" style=\"background:linear-gradient(to top, rgba(37,79,34,0.6) 0%, transparent 55%)\"><span class=\"text-xs font-medium\" style=\"color:#FDFAF5;font-family:var(--font-serif)\">Morning hike</span></div></div><div class=\"absolute rounded-2xl overflow-hidden shadow-2xl\" style=\"top:10px;right:30px;width:180px;height:220px;transform:rotate(3deg);border:4px solid rgba(255,255,255,0.9)\"><img src=\"/card2.jpg\" alt=\"\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 flex items-end p-3\" style=\"background:linear-gradient(to top, rgba(124,74,45,0.6) 0%, transparent 55%)\"><span class=\"text-xs font-medium\" style=\"color:#FDFAF5;font-family:var(--font-serif)\">Golden hour</span></div></div><div class=\"absolute rounded-2xl overflow-hidden shadow-2xl\" style=\"top:160px;left:70px;width:240px;height:270px;transform:rotate(1deg);border:4px solid rgba(255,255,255,0.95);z-index:10\"><img src=\"/card3.jpg\" alt=\"\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 flex items-end p-3\" style=\"background:linear-gradient(to top, rgba(27,58,107,0.6) 0%, transparent 55%)\"><span class=\"text-xs font-medium\" style=\"color:#FDFAF5;font-family:var(--font-serif)\">Lake at dusk</span></div></div><div class=\"absolute rounded-2xl overflow-hidden shadow-2xl\" style=\"bottom:30px;right:20px;width:190px;height:190px;transform:rotate(-2deg);border:4px solid rgba(255,255,255,0.9)\"><img src=\"/card4.jpg\" alt=\"\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 flex items-end p-3\" style=\"background:linear-gradient(to top, rgba(139,111,78,0.6) 0%, transparent 55%)\"><span class=\"text-xs font-medium\" style=\"color:#FDFAF5;font-family:var(--font-serif)\">Wild flowers</span></div></div><div class=\"absolute rounded-2xl px-4 py-3 shadow-xl\" style=\"top:270px;right:15px;background:rgba(255,255,255,0.92);border:1px solid rgba(221,213,197,0.8);z-index:20;backdrop-filter:blur(8px)\"><p class=\"text-xs font-semibold\" style=\"color:#254F22\">✦ 12 photos added</p><p class=\"text-xs\" style=\"color:#8B6F4E\">by 5 people</p></div></div></div></div><div class=\"max-w-6xl mx-auto px-8 py-12\"><div class=\"flex items-center gap-6\"><div class=\"flex-1 h-px\" style=\"background:#E8E0D0\"></div><p class=\"text-sm italic\" style=\"color:#B0A090;font-family:var(--font-serif);white-space:nowrap\">how it works</p><div class=\"flex-1 h-px\" style=\"background:#E8E0D0\"></div></div></div><section class=\"max-w-4xl mx-auto px-8 pb-20\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\"><div class=\"flex flex-col gap-3\"><span style=\"font-family:var(--font-serif);font-size:2.5rem;color:#DDD5C5;font-weight:700;line-height:1\">01</span><h3 class=\"font-semibold text-lg\" style=\"color:#254F22\">Create an album</h3><p class=\"text-sm leading-relaxed\" style=\"color:#7C5C3E\">Give it a name and get a unique link instantly. No account needed.</p></div><div class=\"flex flex-col gap-3\"><span style=\"font-family:var(--font-serif);font-size:2.5rem;color:#DDD5C5;font-weight:700;line-height:1\">02</span><h3 class=\"font-semibold text-lg\" style=\"color:#254F22\">Share the link</h3><p class=\"text-sm leading-relaxed\" style=\"color:#7C5C3E\">Send it via message, display a QR code at your event, or email it.</p></div><div class=\"flex flex-col gap-3\"><span style=\"font-family:var(--font-serif);font-size:2.5rem;color:#DDD5C5;font-weight:700;line-height:1\">03</span><h3 class=\"font-semibold text-lg\" style=\"color:#254F22\">Collect memories</h3><p class=\"text-sm leading-relaxed\" style=\"color:#7C5C3E\">Everyone adds photos. You own the album forever — it never expires.</p></div></div></section><section class=\"mx-8 mb-16 rounded-3xl overflow-hidden\" style=\"background:linear-gradient(135deg, #254F22 0%, #1B3A6B 100%)\"><div class=\"px-12 py-14 flex flex-col md:flex-row items-center justify-between gap-8\"><div><h2 style=\"font-family:var(--font-serif);color:#FDFAF5;font-size:2rem;font-weight:700;margin-bottom:0.5rem\">Ready to preserve a moment?</h2><p style=\"color:#B8D9B2\">Free forever for small albums. No credit card required.</p></div><button class=\"flex items-center gap-2 font-semibold rounded-2xl px-8 py-4 transition hover:opacity-90 whitespace-nowrap\" style=\"background:#FDFAF5;color:#254F22\">Start for free <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button></div></section><footer class=\"px-8 py-6 flex items-center justify-between text-sm\" style=\"border-top:1px solid #E8E0D0\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-4 h-4\" aria-hidden=\"true\" style=\"color:#254F22\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg><span style=\"font-family:var(--font-serif);color:#254F22;font-weight:600\">Memories</span></div><span style=\"color:#B0A090\">© <!-- -->2026<!-- --> — your moments, always.</span></footer></main><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-1dbe8017801b8c18.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[9766,[],\\\"\\\"]\\n3:I[8924,[],\\\"\\\"]\\n4:I[1959,[],\\\"ClientPageRoot\\\"]\\n5:I[7247,[\\\"730\\\",\\\"static/chunks/44530001-2a95bb40d7cb4c97.js\\\",\\\"586\\\",\\\"static/chunks/586-23ccab3f67b0214a.js\\\",\\\"974\\\",\\\"static/chunks/app/page-67397725b32